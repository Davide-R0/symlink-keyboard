/* src-zmk/boards/shields/my_shield/my_shield.dtsi */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    /* Definiamo il trasformatore logico */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        
        /* * Dimensioni totali della matrice LOGICA (Master + Slave).
         * 6 colonne a sinistra + 6 a destra = 12 colonne totali.
         * Assumiamo 5 righe elettriche (4 per le dita + 1 per il pollice).
         */
        columns = <12>;
        rows = <5>;

        /*
         * Qui disegniamo letteralmente la tastiera usando la macro RC(riga, colonna).
         * L'ordine in cui scrivi queste macro è ESATTAMENTE l'ordine 
         * in cui dovrai scrivere i tasti nel file .keymap.
         */
        map = <
        // LATO SINISTRO (colonne 0-5)                 // LATO DESTRO (colonne 6-11 per via del col-offset=6)
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)    RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)    RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)    RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
        RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)    RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
        
        // TASTI POLLICE: Assumiamo che elettricamente usino la riga 4.
        // Li sfalsiamo visivamente per allinearli come nel mondo reale.
                        RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)    RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10)
        >;
    };
};
